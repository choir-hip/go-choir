#!/usr/bin/env bash
set -euo pipefail

install_service_pointer_from_src() {
  local service="$1"
  local src="$2"
  local root="/var/lib/go-choir/services"
  local current="$root/$service"
  local previous="$root/${service}-previous"
  local next="$root/.${service}-next"

  if [ ! -x "$src/bin/$service" ]; then
    echo "Host service package missing executable $service at $src" >&2
    exit 1
  fi

  install -d -m 0755 "$root"
  rm -rf "$next"
  mkdir -p "$next"
  cp -a "$src/." "$next/"
  rm -rf "$previous"
  if [ -e "$current" ]; then
    mv "$current" "$previous"
  fi
  mv "$next" "$current"
  echo "    Host service pointer updated from NixOS closure: $service -> $current"
}

last_literal_exec_target() {
  local wrapper="$1"
  local line
  local target=

  while IFS= read -r line; do
    if [[ "$line" =~ ^[[:space:]]*exec[[:space:]]+\"(/[^\"]+)\" ]]; then
      target="${BASH_REMATCH[1]}"
    elif [[ "$line" =~ ^[[:space:]]*exec[[:space:]]+(/[^[:space:]]+) ]]; then
      target="${BASH_REMATCH[1]}"
    fi
  done < "$wrapper"

  if [ -z "$target" ]; then
    return 1
  fi
  printf '%s\n' "$target"
}

is_direct_store_child() {
  local path="$1"
  local store_root="$2"
  local child

  case "$path" in
    "$store_root"/*) child="${path#"$store_root"/}" ;;
    *) return 1 ;;
  esac
  [ -n "$child" ] && [[ "$child" != */* ]] && [ "$child" != "." ] && [ "$child" != ".." ]
}

is_canonical_nonsymlink() {
  local path="$1"
  local canonical

  [ ! -L "$path" ] || return 1
  canonical="$(realpath -e -- "$path")" || return 1
  [ "$canonical" = "$path" ]
}

resolve_service_package() {
  local service="$1"
  local current="$2"
  local store_root="${3:-/nix/store}"
  local target
  local package
  local resolved_target
  local depth
  local -A seen=()

  for depth in 1 2 3 4; do
    if ! is_direct_store_child "$current" "$store_root"; then
      echo "Nix exec wrapper is outside the immutable store: $current" >&2
      return 1
    fi
    if [ ! -r "$current" ]; then
      echo "Could not read Nix exec wrapper $current for go-choir-$service.service" >&2
      return 1
    fi
    if ! is_canonical_nonsymlink "$current"; then
      echo "Nix exec wrapper is symlinked or noncanonical: $current" >&2
      return 1
    fi
    if [ -n "${seen[$current]+x}" ]; then
      echo "Cycle in Nix exec wrappers at $current for go-choir-$service.service" >&2
      return 1
    fi
    seen["$current"]=1

    if ! target="$(last_literal_exec_target "$current")"; then
      echo "Could not find literal Nix exec target in wrapper $current for go-choir-$service.service" >&2
      return 1
    fi
    if [[ "$target" == */bin/"$service" ]]; then
      package="${target%/bin/$service}"
      if ! is_direct_store_child "$package" "$store_root"; then
        echo "Nix service package is outside the immutable store: $package" >&2
        return 1
      fi
      if ! is_canonical_nonsymlink "$package"; then
        echo "Nix service package is symlinked or noncanonical: $package" >&2
        return 1
      fi
      if [ ! -x "$target" ]; then
        echo "Nix service package missing executable $target" >&2
        return 1
      fi
      if ! resolved_target="$(realpath -e -- "$target")" ||
        [[ "$resolved_target" != "$store_root"/* ]]; then
        echo "Nix service executable resolves outside the immutable store: $target" >&2
        return 1
      fi
      printf '%s\n' "$package"
      return 0
    fi
    if [[ "$target" == */bin/* ]]; then
      echo "Nix wrapper $current resolves to wrong service binary $target for go-choir-$service.service" >&2
      return 1
    fi
    current="$target"
  done

  echo "Nix exec wrapper depth exceeded for go-choir-$service.service" >&2
  return 1
}

resolve_service_package_from_unit() {
  local service="$1"
  local store_root="${2:-/nix/store}"
  local unit="go-choir-${service}.service"
  local wrapper

  wrapper="$(
    { systemctl show "$unit" -p ExecStart --value 2>/dev/null || true; } |
      sed -n 's/^.*path=\([^ ;]*\).*$/\1/p' |
      head -n 1
  )"
  if [ -z "$wrapper" ] || [ ! -r "$wrapper" ]; then
    echo "Could not find readable ExecStart wrapper for $unit" >&2
    return 1
  fi
  resolve_service_package "$service" "$wrapper" "$store_root"
}

main() {
  if [ "$#" -eq 0 ]; then
    echo "usage: $0 <service>..." >&2
    return 64
  fi

  local service
  local package

  for service in "$@"; do
    # go-choir-sandbox was intentionally deleted in PR 5 of
    # store-consolidation. Its package pointer is installed by a NixOS
    # activation script; all service arguments accepted here require units.
    package="$(resolve_service_package_from_unit "$service")"
    install_service_pointer_from_src "$service" "$package"
  done
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi

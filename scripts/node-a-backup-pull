#!/usr/bin/env bash
# Node A backup pull — pulls backup artifacts from Node B via rsync.
#
# This script is the operator/CI entry point for triggering a backup pull
# from Node B to the local Node A host. The NixOS config embeds an
# equivalent script as a systemd service for the daily timer.
#
# Usage:
#   scripts/node-a-backup-pull [--host go-choir-node-b]
#
# Pulls:
#   - Dolt platform DB (/var/lib/go-choir/platform-dolt)
#   - Auth DB (/var/lib/go-choir/auth)
#   - Source service DB (/var/lib/go-choir/source-service)
#   - Mail DB (/var/lib/go-choir/mail)
#   - VM state snapshots (/var/lib/go-choir/vm-state)
#
# Each pull is recorded in a JSON manifest with timestamps and file counts.
set -euo pipefail

node_b_host="${NODE_B_HOST:-go-choir-node-b}"
backup_root="${NODE_A_BACKUP_ROOT:-/var/lib/go-choir-a/backups}"
manifest_dir="${backup_root}/manifests"

mkdir -p \
  "$manifest_dir" \
  "$backup_root/dolt" \
  "$backup_root/auth" \
  "$backup_root/source" \
  "$backup_root/mail" \
  "$backup_root/vm-state"

pull_ts=$(date -u +%Y%m%dT%H%M%SZ)
manifest="$manifest_dir/pull-$pull_ts.json"
started_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)

echo "==> Node A backup pull started at $started_at"
echo "    Source: $node_b_host"
echo "    Manifest: $manifest"

echo "{\"started_at\":\"$started_at\",\"source\":\"$node_b_host\",\"artifacts\":{}}" > "$manifest"

pull_artifact() {
  local name="$1"
  local remote_path="$2"
  local local_dir="$3"
  local tmp
  tmp=$(mktemp)
  echo "  Pulling $name from $remote_path"
  if rsync -a --delete --info=progress2,stats2 \
    "$node_b_host:$remote_path/" "$local_dir/" 2>"$tmp"; then
    local file_count
    file_count=$(find "$local_dir" -type f | wc -l | tr -d ' ')
    local total_size
    total_size=$(du -sh "$local_dir" | cut -f1)
    local tmp2
    tmp2=$(mktemp)
    jq ".artifacts.\"$name\" = {\"status\":\"pass\",\"files\":$file_count,\"size\":\"$total_size\"}" \
      "$manifest" > "$tmp2" && mv "$tmp2" "$manifest"
    echo "  PASS: $name ($file_count files, $total_size)"
  else
    local err
    err=$(head -5 "$tmp" | tr '\n' ' ' | sed 's/"/\\"/g')
    local tmp2
    tmp2=$(mktemp)
    jq ".artifacts.\"$name\" = {\"status\":\"fail\",\"error\":\"$err\"}" \
      "$manifest" > "$tmp2" && mv "$tmp2" "$manifest"
    echo "  FAIL: $name — $err" >&2
  fi
  rm -f "$tmp"
}

pull_artifact "dolt_platform" "/var/lib/go-choir/platform-dolt" "$backup_root/dolt"
pull_artifact "auth_db" "/var/lib/go-choir/auth" "$backup_root/auth"
pull_artifact "source_db" "/var/lib/go-choir/source-service" "$backup_root/source"
pull_artifact "mail_db" "/var/lib/go-choir/mail" "$backup_root/mail"
pull_artifact "vm_state" "/var/lib/go-choir/vm-state" "$backup_root/vm-state"

finished_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)
tmp=$(mktemp)
jq ".finished_at = \"$finished_at\"" "$manifest" > "$tmp" && mv "$tmp" "$manifest"

echo
echo "==> Backup pull complete"
echo "    Manifest: $manifest"
cat "$manifest"

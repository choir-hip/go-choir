#!/usr/bin/env bash
# Read-only acceptance checker for real Choir Email v0 provider proof.
set -euo pipefail

OWNER_ID=""
MESSAGE_ID=""
SUBJECT_CONTAINS=""
NODE_HOST="${CHOIR_MAIL_NODE_HOST:-node-b}"
EXPECT_ATTACHMENT_QUARANTINE=0
EXPECT_INGRESS_EVENTS=""
EXPECT_NO_SENT_AFTER_MESSAGE=0

usage() {
  cat <<'USAGE'
Usage:
  scripts/mail-acceptance-check --owner OWNER [--message ID | --subject TEXT] [options]

Options:
  --owner ID                         Mailbox owner id
  --message ID                       Exact maild message id to verify
  --subject TEXT                     Find newest inbox/quarantine message containing TEXT
  --node-host HOST                   SSH host for Node B. Default: node-b
  --expect-attachment-quarantine     Require at least one quarantined attachment
  --expect-ingress-events N          Require exactly N owner/message ingress events
  --expect-no-sent-after-message     Require no Sent rows at/after selected message timestamp
  -h, --help                         Show this help

This checker is read-only. It uses maildctl over SSH and does not submit the
message to Choir. Use it before owner handoff with --expect-ingress-events 0,
then after clicking Respond with Choir with --expect-ingress-events 1. Add
--expect-no-sent-after-message before owner action to prove inbound mail did
not create an outbound Sent row.
USAGE
}

while [ $# -gt 0 ]; do
  case "$1" in
    --owner)
      OWNER_ID="${2:?missing value for --owner}"
      shift 2
      ;;
    --message)
      MESSAGE_ID="${2:?missing value for --message}"
      shift 2
      ;;
    --subject)
      SUBJECT_CONTAINS="${2:?missing value for --subject}"
      shift 2
      ;;
    --node-host)
      NODE_HOST="${2:?missing value for --node-host}"
      shift 2
      ;;
    --expect-attachment-quarantine)
      EXPECT_ATTACHMENT_QUARANTINE=1
      shift
      ;;
    --expect-ingress-events)
      EXPECT_INGRESS_EVENTS="${2:?missing value for --expect-ingress-events}"
      shift 2
      ;;
    --expect-no-sent-after-message)
      EXPECT_NO_SENT_AFTER_MESSAGE=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "error: unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "error: required command not found: $1" >&2
    exit 1
  fi
}

require_command jq
require_command ssh

if [ -z "$OWNER_ID" ]; then
  echo "error: --owner is required" >&2
  exit 2
fi
if [ -z "$MESSAGE_ID" ] && [ -z "$SUBJECT_CONTAINS" ]; then
  echo "error: --message or --subject is required" >&2
  exit 2
fi
if [ -n "$EXPECT_INGRESS_EVENTS" ] && ! [[ "$EXPECT_INGRESS_EVENTS" =~ ^[0-9]+$ ]]; then
  echo "error: --expect-ingress-events must be a non-negative integer" >&2
  exit 2
fi

maildctl_json() {
  ssh "$NODE_HOST" maildctl "$@"
}

find_message() {
  local folder="$1"
  maildctl_json messages --owner "$OWNER_ID" "$folder" \
    | jq --arg id "$MESSAGE_ID" --arg subject "$SUBJECT_CONTAINS" --arg folder "$folder" '
      map(select(
        (if $id != "" then .ID == $id else true end)
        and (if $subject != "" then (.Subject // "" | contains($subject)) else true end)
      ))
      | .[0] // empty
      | if type == "object" then . + {Folder: $folder} else empty end
    '
}

stats="$(maildctl_json stats)"
webhooks="$(maildctl_json webhooks --limit 100)"

message="$(find_message inbox)"
if [ -z "$message" ]; then
  message="$(find_message quarantine)"
fi
if [ -z "$message" ]; then
  echo "error: no matching inbox/quarantine message found" >&2
  jq -n --arg owner "$OWNER_ID" --arg message "$MESSAGE_ID" --arg subject "$SUBJECT_CONTAINS" '{owner: $owner, message: $message, subject: $subject}'
  exit 1
fi

MESSAGE_ID="$(jq -r '.ID' <<<"$message")"
folder="$(jq -r '.Folder' <<<"$message")"
detail="$(maildctl_json message --owner "$OWNER_ID" --message "$MESSAGE_ID")"
attachments="$(maildctl_json attachments --owner "$OWNER_ID" --message "$MESSAGE_ID")"
source_packet="$(maildctl_json source-packet --owner "$OWNER_ID" --message "$MESSAGE_ID")"
ingress_events="$(maildctl_json ingress-events --owner "$OWNER_ID" --message "$MESSAGE_ID")"
sent_messages_after_message="[]"

provider_message_id="$(jq -r '.message.ProviderMessageID // empty' <<<"$detail")"
provider_event_id="$(jq -r '.message.ProviderEventID // empty' <<<"$detail")"
if [ -z "$provider_message_id" ] || [ -z "$provider_event_id" ]; then
  echo "error: message is missing provider ids; provider_message_id=${provider_message_id:-<empty>} provider_event_id=${provider_event_id:-<empty>}" >&2
  exit 1
fi
matching_webhooks="$(jq --arg provider_message_id "$provider_message_id" --arg provider_event_id "$provider_event_id" '
  [
    .[]
    | select(.ProviderEventID == $provider_event_id or .ProviderMessageID == $provider_message_id)
  ]' <<<"$webhooks")"
matching_webhook_count="$(jq 'length' <<<"$matching_webhooks")"
if [ "$matching_webhook_count" -eq 0 ]; then
  echo "error: no recent webhook receipt matches provider_message_id=${provider_message_id} provider_event_id=${provider_event_id}" >&2
  exit 1
fi

trust_label="$(jq -r '.source_packet.TrustLabel // empty' <<<"$source_packet")"
if [ "$trust_label" != "UNTRUSTED_EXTERNAL_EMAIL" ]; then
  echo "error: source packet trust label = ${trust_label}, want UNTRUSTED_EXTERNAL_EMAIL" >&2
  exit 1
fi

if [ "$EXPECT_ATTACHMENT_QUARANTINE" -eq 1 ]; then
  attachment_count="$(jq 'length' <<<"$attachments")"
  quarantined_count="$(jq '[.[] | select(.Status == "quarantined")] | length' <<<"$attachments")"
  if [ "$attachment_count" -eq 0 ] || [ "$attachment_count" -ne "$quarantined_count" ]; then
    echo "error: expected all attachments to be quarantined; attachments=${attachment_count} quarantined=${quarantined_count}" >&2
    exit 1
  fi
fi

ingress_count="$(jq 'length' <<<"$ingress_events")"
if [ -n "$EXPECT_INGRESS_EVENTS" ] && [ "$ingress_count" -ne "$EXPECT_INGRESS_EVENTS" ]; then
  echo "error: ingress event count = ${ingress_count}, want ${EXPECT_INGRESS_EVENTS}" >&2
  exit 1
fi

if [ "$EXPECT_NO_SENT_AFTER_MESSAGE" -eq 1 ]; then
  message_time="$(jq -r '.message.ReceivedAt // .message.CreatedAt // empty' <<<"$detail")"
  if [ -z "$message_time" ]; then
    echo "error: message has no timestamp for no-outbound comparison" >&2
    exit 1
  fi
  sent_messages="$(maildctl_json messages --owner "$OWNER_ID" sent)"
  sent_messages_after_message="$(jq --arg message_time "$message_time" '
    [
      .[]
      | . as $sent
      | (($sent.SentAt // $sent.CreatedAt // "") | select(. >= $message_time)) as $sent_time
      | $sent + {ComparisonTime: $sent_time}
    ]' <<<"$sent_messages")"
  sent_after_count="$(jq 'length' <<<"$sent_messages_after_message")"
  if [ "$sent_after_count" -ne 0 ]; then
    echo "error: found ${sent_after_count} sent message(s) at/after inbound message timestamp ${message_time}" >&2
    exit 1
  fi
fi

jq -n \
  --arg status "ok" \
  --arg owner "$OWNER_ID" \
  --arg folder "$folder" \
  --argjson stats "$stats" \
  --argjson latest_webhooks "$webhooks" \
  --argjson matching_webhook_events "$matching_webhooks" \
  --argjson message "$message" \
  --argjson detail "$detail" \
  --argjson attachments "$attachments" \
  --argjson source_packet "$source_packet" \
  --argjson ingress_events "$ingress_events" \
  --argjson sent_messages_after_message "$sent_messages_after_message" \
  '{
    status: $status,
    owner: $owner,
    folder: $folder,
    stats: $stats,
    latest_webhooks: $latest_webhooks,
    matching_webhook_events: $matching_webhook_events,
    message: $message,
    detail: $detail,
    attachments: $attachments,
    source_packet: $source_packet,
    ingress_events: $ingress_events,
    sent_messages_after_message: $sent_messages_after_message
  }'

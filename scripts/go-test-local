#!/usr/bin/env bash
set -euo pipefail

echo "Running non-agentcore Go tests"
mapfile -t packages < <(go list ./... | grep -Ev '^github.com/yusefmosiah/go-choir/internal/(agentcore|textureowner)$')
if (( ${#packages[@]} > 0 )); then
  "$(dirname "$0")/go-test-with-timing" -count=1 "${packages[@]}"
fi

echo "Running sharded agentcore and textureowner Go tests"
"$(dirname "$0")/go-test-runtime-shards" "$@"

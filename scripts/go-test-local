#!/usr/bin/env bash
set -euo pipefail

echo "Running non-runtime Go tests"
mapfile -t packages < <(go list ./... | grep -v '^github.com/yusefmosiah/go-choir/internal/runtime$')
if (( ${#packages[@]} > 0 )); then
  "$(dirname "$0")/go-test-with-timing" -count=1 "${packages[@]}"
fi

echo "Running sharded internal/runtime Go tests"
"$(dirname "$0")/go-test-runtime-shards" "$@"

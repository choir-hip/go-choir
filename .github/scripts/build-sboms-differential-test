#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "$0")" && pwd)"
builder="$script_dir/build-sboms-differential"
tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT

mkdir -p "$tmpdir/bin" "$tmpdir/fake-outputs" "$tmpdir/fake-store" "$tmpdir/fake-tool/bin"
packages=(auth proxy gateway maild maildctl corpusd sandbox sourcecycled vmctl frontend obscura zot)
for package in "${packages[@]}"; do
  mkdir -p "$tmpdir/fake-outputs/$package" "$tmpdir/fake-store"
  jq -n --arg package "$package" \
    '{bomFormat: "CycloneDX", components: [{name: $package, version: "1", purl: ("pkg:generic/" + $package + "@1")} ]}' \
    > "$tmpdir/fake-outputs/$package/sbom.json"
done

cat > "$tmpdir/bin/nix" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

semantic_packages=" auth proxy gateway maild maildctl corpusd sandbox sourcecycled vmctl frontend "
revision="${FAKE_REVISION:-one}"
suffix=""
command="$1"
shift
case "$command" in
  eval)
    [[ "$1" == "--raw" ]]
    attr="$2"
    package="${attr%.drvPath}"
    package="${package%.outPath}"
    package="${package##*.}"
    package="${package#.#}"
    package="${package#\#}"
    if [[ "$semantic_packages" == *" $package "* ]]; then
      suffix="-$revision"
    fi
    case "$attr" in
      .#sbom.*.drvPath)
        printf '/nix/store/fake-sbom-%s%s.drv' "$package" "$suffix"
        ;;
      .#*.drvPath)
        printf '/nix/store/fake-artifact-%s%s.drv' "$package" "$suffix"
        ;;
      .#*.outPath)
        printf '%s/%s%s' "$FAKE_STORE_ROOT" "$package" "$suffix"
        ;;
      *)
        echo "unexpected fake nix eval attribute: $attr" >&2
        exit 2
        ;;
    esac
    ;;
  build)
    attr=""
    for arg in "$@"; do
      if [[ "$arg" == .#* || "$arg" == github:* ]]; then
        attr="$arg"
      fi
    done
    printf '%s\n' "$attr" >> "$FAKE_BUILD_LOG"
    if [[ "$attr" == github:*#sbomnix ]]; then
      printf '%s\n' "$FAKE_SBOMNIX_BIN"
    elif [[ "$attr" == .#packages.* ]]; then
      package="${attr##*.}"
      suffix=""
      if [[ "$semantic_packages" == *" $package "* ]]; then
        suffix="-$revision"
      fi
      printf '%s/%s%s\n' "$FAKE_STORE_ROOT" "$package" "$suffix"
    else
      echo "unexpected fake nix build attribute: $attr" >&2
      exit 2
    fi
    ;;
  *)
    echo "unexpected fake nix command: $command $*" >&2
    exit 2
    ;;
esac
EOF
chmod +x "$tmpdir/bin/nix"

cat > "$tmpdir/fake-tool/bin/sbomnix" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
[[ "$1" == "--cdx" ]]
output="$2"
store_path="$3"
identity="${store_path##*/}"
package="${identity%%-*}"
revision="${identity#"$package"}"
artifact_derivation="/nix/store/fake-artifact-${package}${revision}.drv"
printf '%s\n' "$package" >> "$FAKE_SBOMNIX_LOG"
jq \
  --arg drv "$artifact_derivation" \
  --arg out "$store_path" '
    . + {
      serialNumber: "urn:uuid:00000000-0000-4000-8000-000000000000",
      metadata: {
        timestamp: "2026-01-01T00:00:00Z",
        component: {
          "bom-ref": $drv,
          properties: [
            {name: "nix:output_path", value: $out},
            {name: "nix:drv_path", value: $drv}
          ]
        }
      },
      dependencies: [{ref: $drv}]
    }
  ' "$FAKE_OUTPUT_ROOT/$package/sbom.json" > "$output"
EOF
chmod +x "$tmpdir/fake-tool/bin/sbomnix"

cat > "$tmpdir/bin/fingerprint" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
package="$1"
suffix=""
if [[ "${FAKE_CHANGED_PACKAGE:-}" == "$package" ]]; then
  suffix="-changed"
fi
printf 'semantic-%s%s' "$package" "$suffix" | sha256sum | awk '{print $1}'
EOF
chmod +x "$tmpdir/bin/fingerprint"

export PATH="$tmpdir/bin:$PATH"
export FAKE_OUTPUT_ROOT="$tmpdir/fake-outputs"
export FAKE_STORE_ROOT="$tmpdir/fake-store"
export FAKE_SBOMNIX_BIN="$tmpdir/fake-tool"
export FAKE_BUILD_LOG="$tmpdir/build.log"
export FAKE_SBOMNIX_LOG="$tmpdir/sbomnix.log"
export SBOM_FINGERPRINT_BIN="$tmpdir/bin/fingerprint"
export SBOM_NIX_GO_VERSION="$(go env GOVERSION)"
export SBOM_NIX_GO_VERSION="${SBOM_NIX_GO_VERSION#go}"
export FAKE_REVISION=one

: > "$FAKE_BUILD_LOG"
: > "$FAKE_SBOMNIX_LOG"
"$builder" "$tmpdir/first" "" first-commit >/dev/null
[[ "$(grep -c '^\.#' "$FAKE_BUILD_LOG")" == "12" ]]
[[ "$(grep -c '^github:tiiuae/sbomnix/30c95eb2fc0c402300ee05354c5cf84c7e5f74e2#sbomnix$' "$FAKE_BUILD_LOG")" == "1" ]]
! grep -q '^\.#sbom\.' "$FAKE_BUILD_LOG"
[[ "$(wc -l < "$FAKE_SBOMNIX_LOG" | tr -d ' ')" == "12" ]]
[[ "$(jq -s 'map(select(.status == "built")) | length' "$tmpdir/first/manifest.jsonl")" == "12" ]]

export FAKE_REVISION=two
: > "$FAKE_BUILD_LOG"
: > "$FAKE_SBOMNIX_LOG"
"$builder" "$tmpdir/second" "$tmpdir/first" second-commit >/dev/null
[[ ! -s "$FAKE_BUILD_LOG" ]]
[[ ! -s "$FAKE_SBOMNIX_LOG" ]]
[[ "$(jq -s 'map(select(.status == "rebound")) | length' "$tmpdir/second/manifest.jsonl")" == "10" ]]
[[ "$(jq -s 'map(select(.status == "reused")) | length' "$tmpdir/second/manifest.jsonl")" == "2" ]]
jq -se 'map(select(.status == "rebound")) | all(.reason == "identical_semantic_fingerprint" and .artifact_derivation != .previous_derivation)' \
  "$tmpdir/second/manifest.jsonl" >/dev/null
grep -Fq '/nix/store/fake-artifact-auth-two.drv' "$tmpdir/second/auth/sbom.json"

cp -a "$tmpdir/second" "$tmpdir/legacy-baseline"
legacy_commit="$(git rev-parse HEAD)"
jq -c --arg commit "$legacy_commit" \
  '.source_commit = $commit | del(.semantic_fingerprint, .previous_semantic_fingerprint)' \
  "$tmpdir/legacy-baseline/manifest.jsonl" > "$tmpdir/legacy-baseline/manifest.next"
mv "$tmpdir/legacy-baseline/manifest.next" "$tmpdir/legacy-baseline/manifest.jsonl"
export FAKE_REVISION=legacy
: > "$FAKE_BUILD_LOG"
: > "$FAKE_SBOMNIX_LOG"
"$builder" "$tmpdir/legacy-rebound" "$tmpdir/legacy-baseline" legacy-current >/dev/null
[[ ! -s "$FAKE_BUILD_LOG" ]]
[[ ! -s "$FAKE_SBOMNIX_LOG" ]]
[[ "$(jq -s 'map(select(.status == "rebound")) | length' "$tmpdir/legacy-rebound/manifest.jsonl")" == "10" ]]
[[ "$(jq -s 'map(select(.status == "reused")) | length' "$tmpdir/legacy-rebound/manifest.jsonl")" == "2" ]]
! grep -Fq '/nix/store/fake-artifact-auth-one.drv' "$tmpdir/second/auth/sbom.json"

cp -a "$tmpdir/second" "$tmpdir/failure-baseline"
mv "$tmpdir/failure-baseline/obscura/sbom.json" "$tmpdir/failure-baseline/obscura/sbom.unavailable"
jq -c 'if .package == "obscura" then .status = "failed" | .reason = "package_build_failed" | del(.sbom_sha256) else . end' \
  "$tmpdir/failure-baseline/manifest.jsonl" > "$tmpdir/failure-baseline/manifest.jsonl.next"
mv "$tmpdir/failure-baseline/manifest.jsonl.next" "$tmpdir/failure-baseline/manifest.jsonl"
export FAKE_REVISION=two
: > "$FAKE_BUILD_LOG"
: > "$FAKE_SBOMNIX_LOG"
"$builder" "$tmpdir/failure-reuse" "$tmpdir/failure-baseline" failure-reuse-commit >/dev/null
[[ ! -s "$FAKE_BUILD_LOG" ]]
[[ ! -s "$FAKE_SBOMNIX_LOG" ]]
[[ "$(jq -s 'map(select(.status == "reused")) | length' "$tmpdir/failure-reuse/manifest.jsonl")" == "11" ]]
jq -se 'map(select(.package == "obscura"))[0] | .status == "skipped" and .reason == "unchanged_previous_failure" and .previous_reason == "package_build_failed"' \
  "$tmpdir/failure-reuse/manifest.jsonl" >/dev/null
: > "$FAKE_BUILD_LOG"
: > "$FAKE_SBOMNIX_LOG"
"$builder" "$tmpdir/failure-reuse-again" "$tmpdir/failure-reuse" failure-reuse-again-commit >/dev/null
[[ ! -s "$FAKE_BUILD_LOG" ]]
[[ ! -s "$FAKE_SBOMNIX_LOG" ]]
jq -se 'map(select(.package == "obscura"))[0] | .status == "skipped" and .reason == "unchanged_previous_failure" and .previous_reason == "package_build_failed"' \
  "$tmpdir/failure-reuse-again/manifest.jsonl" >/dev/null

jq '.components[0].version = "2" | .components[0].purl = "pkg:generic/auth@2"' \
  "$tmpdir/fake-outputs/auth/sbom.json" > "$tmpdir/fake-outputs/auth/sbom.json.next"
mv "$tmpdir/fake-outputs/auth/sbom.json.next" "$tmpdir/fake-outputs/auth/sbom.json"
: > "$FAKE_BUILD_LOG"
: > "$FAKE_SBOMNIX_LOG"
export FAKE_REVISION=three
FAKE_CHANGED_PACKAGE=auth "$builder" "$tmpdir/third" "$tmpdir/second" third-commit >/dev/null
[[ "$(grep -c '^\.#packages\.x86_64-linux\.auth$' "$FAKE_BUILD_LOG")" == "1" ]]
[[ "$(grep -c '^github:tiiuae/sbomnix/30c95eb2fc0c402300ee05354c5cf84c7e5f74e2#sbomnix$' "$FAKE_BUILD_LOG")" == "1" ]]
! grep -q '^\.#sbom\.' "$FAKE_BUILD_LOG"
[[ "$(cat "$FAKE_SBOMNIX_LOG")" == "auth" ]]
[[ "$(jq -s 'map(select(.status == "built")) | length' "$tmpdir/third/manifest.jsonl")" == "1" ]]
[[ "$(jq -s 'map(select(.status == "rebound")) | length' "$tmpdir/third/manifest.jsonl")" == "9" ]]
[[ "$(jq -s 'map(select(.status == "reused")) | length' "$tmpdir/third/manifest.jsonl")" == "2" ]]
jq -e '.packages[] | select(.package == "auth") | (.added == ["pkg:generic/auth@2"] and .removed == ["pkg:generic/auth@1"])' \
  "$tmpdir/third/diff.json" >/dev/null

echo "build-sboms-differential: all tests passed"

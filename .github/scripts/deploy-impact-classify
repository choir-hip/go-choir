#!/usr/bin/env bash
set -euo pipefail

output_file="${1:-}"

deploy_needed=false
deploy_host=false
deploy_frontend=false
deploy_host_service=false
deploy_ordinary_guest=false
deploy_playwright_guest=false
deploy_host_os=false
deploy_vmctl_restart=false
deploy_active_vm_refresh=false

declare -a changed=()
declare -a explanations=()
declare -a host_services=()

while IFS= read -r path; do
  [[ -z "$path" ]] && continue
  changed+=("$path")
done

add_explanation() {
  explanations+=("$1")
}

mark_host() {
  deploy_needed=true
  deploy_host=true
}

mark_frontend() {
  deploy_needed=true
  deploy_frontend=true
}

mark_host_service() {
  deploy_needed=true
  deploy_host_service=true
  deploy_host=true
}

add_host_service() {
  local service="$1"
  mark_host_service
  if ((${#host_services[@]} > 0)); then
    for existing in "${host_services[@]}"; do
      [[ "$existing" == "$service" ]] && return
    done
  fi
  host_services+=("$service")
}

mark_vmctl_restart() {
  deploy_vmctl_restart=true
}

mark_active_vm_refresh() {
  deploy_active_vm_refresh=true
}

mark_ordinary_guest() {
  deploy_needed=true
  deploy_ordinary_guest=true
  deploy_vmctl_restart=true
  deploy_active_vm_refresh=true
}

mark_playwright_guest() {
  deploy_needed=true
  deploy_playwright_guest=true
  deploy_vmctl_restart=true
}

mark_host_os() {
  deploy_needed=true
  deploy_host_os=true
  deploy_host=true
  deploy_frontend=true
  deploy_vmctl_restart=true
}

mark_host_os_only() {
  deploy_needed=true
  deploy_host_os=true
  deploy_host=true
  deploy_vmctl_restart=true
}

for path in "${changed[@]}"; do
  case "$path" in
    docs/*|.github/*|scripts/go-test-*|frontend/tests/*|frontend/playwright-report/*|frontend/test-results/*|*_test.go)
      add_explanation "$path -> ignored (docs/workflow/test artifact)"
      continue
      ;;
  esac

  if [[ "$path" != */* && "$path" == *.md ]]; then
    add_explanation "$path -> ignored (top-level markdown)"
    continue
  fi

  case "$path" in
    frontend/src/*|frontend/package.json|frontend/package-lock.json|frontend/svelte.config.js|frontend/vite.config.js|frontend/index.html|frontend/public/*)
      mark_frontend
      add_explanation "$path -> frontend bundle"
      ;;
    cmd/vmctl/*|internal/vmmanager/*)
      add_host_service "vmctl"
      mark_vmctl_restart
      mark_active_vm_refresh
      add_explanation "$path -> vmctl host service closure + vmctl restart + active VM boot-contract refresh"
      ;;
    internal/vmctl/*)
      add_host_service "gateway"
      add_host_service "proxy"
      add_host_service "sandbox"
      add_host_service "vmctl"
      mark_vmctl_restart
      mark_active_vm_refresh
      add_explanation "$path -> vmctl users: gateway/proxy/sandbox/vmctl + vmctl restart + active VM boot-contract refresh"
      ;;
    cmd/auth/*|internal/auth/*)
      add_host_service "auth"
      add_explanation "$path -> auth host service"
      ;;
    cmd/proxy/*|internal/proxy/*)
      add_host_service "proxy"
      add_explanation "$path -> proxy host service"
      ;;
    cmd/maild/*|internal/maild/*)
      add_host_service "maild"
      add_explanation "$path -> maild host service"
      ;;
    cmd/maildctl/*)
      mark_host_os_only
      add_explanation "$path -> maildctl host package in Node B system environment"
      ;;
    cmd/gateway/*)
      add_host_service "gateway"
      add_explanation "$path -> gateway host service"
      ;;
    cmd/sourcecycled/*|internal/cycle/*|internal/sources/*|configs/sources.json)
      add_host_service "sourcecycled"
      add_host_service "sandbox"
      add_explanation "$path -> source service ingestion + sandbox source_search runtime package"
      ;;
    internal/gateway/*|internal/provider/*)
      add_host_service "gateway"
      add_explanation "$path -> host gateway provider boundary"
      ;;
    internal/gatewayruntime/*)
      add_host_service "sandbox"
      add_explanation "$path -> sandbox runtime package"
      ;;
    internal/modelcatalog/*|internal/sandbox/*|internal/store/*)
      add_host_service "gateway"
      add_host_service "sandbox"
      add_explanation "$path -> gateway/sandbox shared runtime dependency"
      ;;
    cmd/platformd/*|internal/promotion/*)
      add_host_service "platformd"
      add_explanation "$path -> platformd host service"
      ;;
    internal/platform/*)
      add_host_service "platformd"
      add_host_service "proxy"
      add_explanation "$path -> platform/proxy shared dependency"
      ;;
    cmd/shipper/*|internal/shipper/*)
      mark_host_service
      add_explanation "$path -> host service closure (no deployed service pointer yet)"
      ;;
    cmd/sandbox/*|internal/sandbox/*|skills/*)
      add_host_service "sandbox"
      add_explanation "$path -> sandbox runtime package"
      ;;
    internal/runtime/model_policy.go)
      add_host_service "sandbox"
      add_explanation "$path -> sandbox runtime package"
      ;;
    internal/runtime/api_trace.go)
      add_host_service "sandbox"
      add_explanation "$path -> sandbox runtime package"
      ;;
    internal/runtime/*)
      add_host_service "gateway"
      add_host_service "sandbox"
      add_explanation "$path -> gateway/sandbox service pointers"
      ;;
    internal/types/*)
      add_host_service "gateway"
      add_host_service "proxy"
      add_host_service "sandbox"
      add_explanation "$path -> shared API types: gateway/proxy/sandbox service pointers"
      ;;
    internal/buildinfo/*)
      add_host_service "gateway"
      add_host_service "maild"
      add_host_service "platformd"
      add_host_service "proxy"
      add_host_service "sandbox"
      add_explanation "$path -> build identity users: gateway/maild/platformd/proxy/sandbox"
      ;;
    internal/events/*)
      add_host_service "gateway"
      add_host_service "sandbox"
      add_explanation "$path -> event bus users: gateway/sandbox service pointers"
      ;;
    internal/server/*)
      add_host_service "auth"
      add_host_service "gateway"
      add_host_service "maild"
      add_host_service "platformd"
      add_host_service "proxy"
      add_host_service "sandbox"
      add_host_service "vmctl"
      mark_vmctl_restart
      add_explanation "$path -> shared HTTP server: all host service pointers + vmctl restart"
      ;;
    internal/search/*)
      add_host_service "sandbox"
      add_explanation "$path -> sandbox search runtime package"
      ;;
    nix/sandbox-vm.nix)
      mark_ordinary_guest
      mark_playwright_guest
      add_explanation "$path -> ordinary + playwright guest images"
      ;;
    flake.nix|flake.lock)
      mark_host_os
      mark_ordinary_guest
      mark_playwright_guest
      add_explanation "$path -> host OS + ordinary + playwright guest images (shared Nix input)"
      ;;
    nix/node-b.nix|nix/hardware.nix|nix/disks.nix)
      mark_host_os_only
      add_explanation "$path -> host OS only"
      ;;
    nix/*)
      mark_host_os
      mark_ordinary_guest
      mark_playwright_guest
      add_explanation "$path -> conservative Nix impact: host OS + both guest images"
      ;;
    go.mod|go.sum)
      mark_host_service
      mark_ordinary_guest
      mark_playwright_guest
      add_explanation "$path -> shared Go/build metadata: host + both guest images"
      ;;
    cmd/*|internal/*)
      mark_host_service
      mark_ordinary_guest
      mark_playwright_guest
      add_explanation "$path -> conservative Go impact: host + both guest images"
      ;;
    frontend/*)
      mark_frontend
      add_explanation "$path -> conservative frontend impact"
      ;;
    *)
      mark_host_os
      mark_ordinary_guest
      mark_playwright_guest
      add_explanation "$path -> unknown deployed path: conservative host + both guest images"
      ;;
  esac
done

if [[ -n "$output_file" ]]; then
  {
    echo "deploy_needed=${deploy_needed}"
    echo "deploy_host=${deploy_host}"
    echo "deploy_frontend=${deploy_frontend}"
    echo "deploy_host_service=${deploy_host_service}"
    echo "deploy_ordinary_guest=${deploy_ordinary_guest}"
    echo "deploy_playwright_guest=${deploy_playwright_guest}"
    echo "deploy_host_os=${deploy_host_os}"
    echo "deploy_vmctl_restart=${deploy_vmctl_restart}"
    echo "deploy_active_vm_refresh=${deploy_active_vm_refresh}"
    echo "host_services=$(IFS=,; echo "${host_services[*]}")"
    echo "changed_paths<<EOF"
    printf '%s\n' "${changed[@]}"
    echo "EOF"
    echo "class_explanation<<EOF"
    printf '%s\n' "${explanations[@]}"
    echo "EOF"
  } >> "$output_file"
fi

cat <<EOF
deploy_needed=${deploy_needed}
deploy_host=${deploy_host}
deploy_frontend=${deploy_frontend}
deploy_host_service=${deploy_host_service}
deploy_ordinary_guest=${deploy_ordinary_guest}
deploy_playwright_guest=${deploy_playwright_guest}
deploy_host_os=${deploy_host_os}
deploy_vmctl_restart=${deploy_vmctl_restart}
deploy_active_vm_refresh=${deploy_active_vm_refresh}
host_services=$(IFS=,; echo "${host_services[*]}")
EOF

printf '%s\n' "${explanations[@]}"

#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
deploy-impact-classify reads changed file paths from stdin, not git SHAs.

Usage:
  git diff --name-only <base>..<head> | .github/scripts/deploy-impact-classify [output-file]
  git diff --name-only --cached       | .github/scripts/deploy-impact-classify

CI example:
  printf '%s\n' "${changed[@]}" | .github/scripts/deploy-impact-classify "$GITHUB_OUTPUT"
EOF
}

looks_like_git_sha() {
  [[ "$1" =~ ^[0-9a-f]{7,40}$ ]]
}

if [[ -t 0 ]]; then
  usage
  exit 1
fi

output_file="${1:-}"
if [[ -n "$output_file" ]] && looks_like_git_sha "$output_file"; then
  printf 'error: %q looks like a git SHA; pipe changed paths on stdin instead\n' "$output_file" >&2
  usage
  exit 1
fi

deploy_needed=false
deploy_host=false
deploy_frontend=false
deploy_host_service=false
deploy_host_os=false
deploy_vmctl_restart=false
deploy_active_vm_refresh=false

declare -a changed=()
declare -a explanations=()
declare -a host_services=()

while IFS= read -r path; do
  [[ -z "$path" ]] && continue
  changed+=("$path")
done

add_explanation() {
  explanations+=("$1")
}

mark_host() {
  deploy_needed=true
  deploy_host=true
}

mark_frontend() {
  deploy_needed=true
  deploy_frontend=true
}

mark_host_service() {
  deploy_needed=true
  deploy_host_service=true
  deploy_host=true
}

add_host_service() {
  local service="$1"
  mark_host_service
  if ((${#host_services[@]} > 0)); then
    for existing in "${host_services[@]}"; do
      [[ "$existing" == "$service" ]] && return
    done
  fi
  host_services+=("$service")
}

mark_vmctl_restart() {
  deploy_vmctl_restart=true
}

mark_active_vm_refresh() {
  deploy_active_vm_refresh=true
}

mark_guest_boot_contract() {
  deploy_needed=true
  deploy_host=true
  deploy_host_os=true
  deploy_vmctl_restart=true
  deploy_active_vm_refresh=true
}


mark_host_os() {
  deploy_needed=true
  deploy_host_os=true
  deploy_host=true
  deploy_frontend=true
  deploy_vmctl_restart=true
}

mark_host_os_only() {
  deploy_needed=true
  deploy_host_os=true
  deploy_host=true
  deploy_vmctl_restart=true
}

for path in "${changed[@]}"; do
  case "$path" in
    .gitignore|cmd/doccheck/*|scripts/doccheck|scripts/node-b-deploy-disk-preflight)
      add_explanation "$path -> ignored (repo metadata or docs checker tooling)"
      continue
      ;;
    cmd/choir/*)
      add_explanation "$path -> ignored (undistributed Choir CLI; not installed on Node B or guest closures)"
      continue
      ;;
    cmd/desktop/*)
      add_explanation "$path -> ignored (native Wails distribution module; not installed on Node B or guest closures)"
      continue
      ;;
    scripts/node-b-storage-*|scripts/node-b-data-img-snapshot|scripts/node-b-nix-root-report)
      add_explanation "$path -> ignored (Node B operator/report tooling; not deployed to host or guest closures)"
      continue
      ;;
    scripts/node-a-*|nix/node-a.nix|nix/node-a-hardware.nix|nix/node-a-disks.nix)
      add_explanation "$path -> ignored (Node A mirror config; not deployed to Node B host or guest closures)"
      continue
      ;;
    start-services.sh)
      add_explanation "$path -> ignored (local developer service harness)"
      continue
      ;;
    scripts/node-b-sync-service-pointers)
      mark_host_os_only
      add_explanation "$path -> host OS activation and immutable service-pointer synchronization"
      continue
      ;;
    docs/*|.github/*|scripts/go-test-*|frontend/tests/*|frontend/playwright-report/*|frontend/test-results/*|*_test.go|internal/*/testdata/*)
      add_explanation "$path -> ignored (docs/workflow/test artifact)"
      continue
      ;;
  esac

  if [[ "$path" != */* && "$path" == *.md ]]; then
    add_explanation "$path -> ignored (top-level markdown)"
    continue
  fi

  case "$path" in
    frontend/src/*|frontend/package.json|frontend/package-lock.json|frontend/svelte.config.js|frontend/vite.config.js|frontend/index.html|frontend/public/*)
      mark_frontend
      add_explanation "$path -> frontend bundle"
      ;;
    cmd/vmctl/*|internal/vmmanager/*)
      add_host_service "vmctl"
      mark_guest_boot_contract
      add_explanation "$path -> vmctl host service + canonical guest boot closure + active VM refresh"
      ;;
    internal/vmctl/*)
      add_host_service "gateway"
      add_host_service "proxy"
      add_host_service "sandbox"
      add_host_service "vmctl"
      mark_guest_boot_contract
      add_explanation "$path -> vmctl users + canonical guest boot closure + active VM refresh"
      ;;
    cmd/auth/*|internal/auth/*)
      add_host_service "auth"
      add_explanation "$path -> auth host service"
      ;;
    cmd/proxy/*|internal/proxy/*)
      add_host_service "proxy"
      add_explanation "$path -> proxy host service"
      ;;
    cmd/maild/*|internal/maild/*)
      add_host_service "maild"
      add_explanation "$path -> maild host service"
      ;;
    cmd/maildctl/*)
      mark_host_os_only
      add_explanation "$path -> maildctl host package in Node B system environment"
      ;;
    cmd/gateway/*)
      add_host_service "gateway"
      add_explanation "$path -> gateway host service"
      ;;
    cmd/sourcecycled/*|internal/cycle/*|internal/sourceapi/*|internal/sources/*|configs/sources.json)
      add_host_service "sourcecycled"
      add_host_service "sandbox"
      add_explanation "$path -> source service API/ingestion + sandbox source_search runtime package"
      ;;
    internal/gateway/*|internal/provider/*)
      add_host_service "gateway"
      add_explanation "$path -> host gateway provider boundary"
      ;;
    internal/gatewayruntime/*)
      add_host_service "sandbox"
      add_explanation "$path -> sandbox runtime package"
      ;;
    internal/modelcatalog/*|internal/sandbox/*|internal/store/*)
      add_host_service "gateway"
      add_host_service "sandbox"
      add_explanation "$path -> gateway/sandbox shared runtime dependency"
      ;;
    cmd/corpusd/*|internal/promotion/*)
      add_host_service "corpusd"
      add_explanation "$path -> corpusd host service"
      ;;
    internal/platform/*)
      add_host_service "corpusd"
      add_host_service "proxy"
      add_explanation "$path -> platform/proxy shared dependency"
      ;;
    internal/wirepublish/*)
      add_host_service "corpusd"
      add_host_service "proxy"
      add_host_service "sandbox"
      add_explanation "$path -> wire autonomous publish: corpusd/proxy choke point + sandbox runtime"
      ;;
    internal/sourcecontract/*)
      add_host_service "gateway"
      add_host_service "corpusd"
      add_host_service "proxy"
      add_host_service "sandbox"
      add_host_service "sourcecycled"
      mark_vmctl_restart
      mark_active_vm_refresh
      add_explanation "$path -> shared source contract dependency: runtime/platform service pointers + active VM refresh"
      ;;
    internal/sourcefetch/*)
      add_host_service "gateway"
      add_host_service "sandbox"
      add_host_service "sourcecycled"
      mark_vmctl_restart
      mark_active_vm_refresh
      add_explanation "$path -> shared source fetch policy dependency: runtime/source service fetch behavior + active VM refresh"
      ;;
    internal/markdownstructure/*)
      add_host_service "gateway"
      add_host_service "corpusd"
      add_host_service "proxy"
      add_host_service "sandbox"
      add_explanation "$path -> shared Markdown structure dependency for runtime/platform publication exports"
      ;;
    cmd/shipper/*|internal/shipper/*)
      mark_host_service
      add_explanation "$path -> host service closure (no deployed service pointer yet)"
      ;;
    cmd/sandbox/*|internal/sandbox/*)
      add_host_service "sandbox"
      mark_vmctl_restart
      add_explanation "$path -> sandbox runtime package + vmctl runtime-package endpoint restart"
      ;;
    internal/agentcore/*|internal/textureowner/*)
      add_host_service "gateway"
      add_host_service "sandbox"
      mark_vmctl_restart
      add_explanation "$path -> gateway/sandbox service pointers + vmctl runtime-package endpoint restart"
      ;;
    internal/types/*)
      add_host_service "gateway"
      add_host_service "proxy"
      add_host_service "sandbox"
      add_explanation "$path -> shared API types: gateway/proxy/sandbox service pointers"
      ;;
    internal/buildinfo/*)
      add_host_service "gateway"
      add_host_service "maild"
      add_host_service "corpusd"
      add_host_service "proxy"
      add_host_service "sandbox"
      add_explanation "$path -> build identity users: gateway/maild/corpusd/proxy/sandbox"
      ;;
    internal/events/*)
      add_host_service "gateway"
      add_host_service "sandbox"
      add_explanation "$path -> event bus users: gateway/sandbox service pointers"
      ;;
    internal/server/*)
      add_host_service "auth"
      add_host_service "gateway"
      add_host_service "maild"
      add_host_service "corpusd"
      add_host_service "proxy"
      add_host_service "sandbox"
      add_host_service "vmctl"
      mark_vmctl_restart
      add_explanation "$path -> shared HTTP server: all host service pointers + vmctl restart"
      ;;
    internal/search/*)
      add_host_service "sandbox"
      add_explanation "$path -> sandbox search runtime package"
      ;;
    skills/*)
      add_host_service "sandbox"
      add_explanation "$path -> sandbox runtime skill package"
      ;;
    nix/sandbox-vm.nix)
      mark_guest_boot_contract
      add_explanation "$path -> canonical guest image"
      ;;
    flake.nix|flake.lock)
      mark_host_os
      mark_guest_boot_contract
      add_explanation "$path -> host OS + canonical guest image (shared Nix input)"
      ;;
    nix/node-b.nix|nix/hardware.nix|nix/disks.nix)
      mark_host_os_only
      add_explanation "$path -> host OS only"
      ;;
    nix/*)
      mark_host_os
      mark_guest_boot_contract
      add_explanation "$path -> conservative Nix impact: host OS + canonical guest image"
      ;;
    go.mod|go.sum)
      mark_host_service
      mark_guest_boot_contract
      add_explanation "$path -> shared Go/build metadata: host + canonical guest image"
      ;;
    cmd/*|internal/*)
      mark_host_service
      mark_guest_boot_contract
      add_explanation "$path -> conservative Go impact: host + canonical guest image"
      ;;
    frontend/*)
      mark_frontend
      add_explanation "$path -> conservative frontend impact"
      ;;
    *)
      mark_host_os
      mark_guest_boot_contract
      add_explanation "$path -> unknown deployed path: conservative host + canonical guest image"
      ;;
  esac
done

# A canonical guest boot refresh executes the sandbox package fetched from the
# host pointer. Rebuild that package at the same deployment commit so refreshed
# guests never combine a new boot closure with a stale executable.
if [[ "$deploy_active_vm_refresh" == "true" ]]; then
  add_host_service "sandbox"
  add_explanation "canonical guest boot refresh -> sandbox runtime package at the same commit"
fi

# A sandbox package is executable inside the guest, not a host-service-only
# artifact. Until a proved in-guest runtime replacement endpoint exists, every
# sandbox selection must rebuild the canonical guest boot closure and refresh
# mutable active computers from that closure.
for service in "${host_services[@]}"; do
  if [[ "$service" == "sandbox" ]]; then
    mark_guest_boot_contract
    add_explanation "sandbox runtime selected -> canonical guest boot closure + active VM refresh"
    break
  fi
done

if [[ -n "$output_file" ]]; then
  {
    echo "deploy_needed=${deploy_needed}"
    echo "deploy_host=${deploy_host}"
    echo "deploy_frontend=${deploy_frontend}"
    echo "deploy_host_service=${deploy_host_service}"
    echo "deploy_host_os=${deploy_host_os}"
    echo "deploy_vmctl_restart=${deploy_vmctl_restart}"
    echo "deploy_active_vm_refresh=${deploy_active_vm_refresh}"
    echo "host_services=$(IFS=,; echo "${host_services[*]}")"
    echo "changed_paths<<EOF"
    printf '%s\n' "${changed[@]}"
    echo "EOF"
    echo "class_explanation<<EOF"
    printf '%s\n' "${explanations[@]}"
    echo "EOF"
  } >> "$output_file"
fi

cat <<EOF
deploy_needed=${deploy_needed}
deploy_host=${deploy_host}
deploy_frontend=${deploy_frontend}
deploy_host_service=${deploy_host_service}
deploy_host_os=${deploy_host_os}
deploy_vmctl_restart=${deploy_vmctl_restart}
deploy_active_vm_refresh=${deploy_active_vm_refresh}
host_services=$(IFS=,; echo "${host_services[*]}")
EOF

printf '%s\n' "${explanations[@]}"

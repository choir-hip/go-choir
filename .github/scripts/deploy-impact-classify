#!/usr/bin/env bash
set -euo pipefail

output_file="${1:-}"

deploy_needed=false
deploy_host=false
deploy_frontend=false
deploy_host_service=false
deploy_ordinary_guest=false
deploy_playwright_guest=false
deploy_host_os=false
deploy_vmctl_restart=false

declare -a changed=()
declare -a explanations=()
declare -a host_services=()

while IFS= read -r path; do
  [[ -z "$path" ]] && continue
  changed+=("$path")
done

add_explanation() {
  explanations+=("$1")
}

mark_host() {
  deploy_needed=true
  deploy_host=true
}

mark_frontend() {
  deploy_needed=true
  deploy_frontend=true
}

mark_host_service() {
  deploy_needed=true
  deploy_host_service=true
  deploy_host=true
}

add_host_service() {
  local service="$1"
  mark_host_service
  for existing in "${host_services[@]}"; do
    [[ "$existing" == "$service" ]] && return
  done
  host_services+=("$service")
}

mark_vmctl_restart() {
  deploy_vmctl_restart=true
}

mark_ordinary_guest() {
  deploy_needed=true
  deploy_ordinary_guest=true
  deploy_vmctl_restart=true
}

mark_playwright_guest() {
  deploy_needed=true
  deploy_playwright_guest=true
  deploy_vmctl_restart=true
}

mark_host_os() {
  deploy_needed=true
  deploy_host_os=true
  deploy_host=true
  deploy_frontend=true
  deploy_vmctl_restart=true
}

for path in "${changed[@]}"; do
  case "$path" in
    docs/*|.github/*|frontend/tests/*|frontend/playwright-report/*|frontend/test-results/*)
      add_explanation "$path -> ignored (docs/workflow/test artifact)"
      continue
      ;;
  esac

  if [[ "$path" != */* && "$path" == *.md ]]; then
    add_explanation "$path -> ignored (top-level markdown)"
    continue
  fi

  case "$path" in
    frontend/src/*|frontend/package.json|frontend/package-lock.json|frontend/svelte.config.js|frontend/vite.config.js|frontend/index.html|frontend/public/*)
      mark_frontend
      add_explanation "$path -> frontend bundle"
      ;;
    cmd/vmctl/*|internal/vmctl/*|internal/vmmanager/*)
      add_host_service "vmctl"
      mark_vmctl_restart
      add_explanation "$path -> vmctl host service closure + vmctl restart"
      ;;
    cmd/auth/*|internal/auth/*)
      add_host_service "auth"
      add_explanation "$path -> auth host service"
      ;;
    cmd/proxy/*|internal/proxy/*)
      add_host_service "proxy"
      add_explanation "$path -> proxy host service"
      ;;
    cmd/gateway/*|internal/gateway/*|internal/provider/*)
      add_host_service "gateway"
      add_explanation "$path -> gateway host service"
      ;;
    cmd/platformd/*|internal/platform/*|internal/modelcatalog/*|internal/promotion/*)
      add_host_service "platformd"
      add_explanation "$path -> platformd host service"
      ;;
    cmd/shipper/*|internal/shipper/*)
      mark_host_service
      add_explanation "$path -> host service closure (no deployed service pointer yet)"
      ;;
    cmd/sandbox/*|internal/runtime/*|internal/sandbox/*|internal/store/*|internal/types/*|internal/events/*|internal/search/*|internal/server/*|skills/*)
      mark_host
      mark_ordinary_guest
      add_explanation "$path -> ordinary guest image + host closure (sandbox/runtime impact)"
      ;;
    nix/sandbox-vm.nix)
      mark_ordinary_guest
      mark_playwright_guest
      add_explanation "$path -> ordinary + playwright guest images"
      ;;
    flake.nix|flake.lock|nix/node-b.nix|nix/hardware.nix|nix/disks.nix)
      mark_host_os
      mark_ordinary_guest
      mark_playwright_guest
      add_explanation "$path -> host OS + ordinary + playwright guest images (shared Nix input)"
      ;;
    nix/*)
      mark_host_os
      mark_ordinary_guest
      mark_playwright_guest
      add_explanation "$path -> conservative Nix impact: host OS + both guest images"
      ;;
    go.mod|go.sum|internal/buildinfo/*)
      mark_host_service
      mark_ordinary_guest
      mark_playwright_guest
      add_explanation "$path -> shared Go/build metadata: host + both guest images"
      ;;
    cmd/*|internal/*)
      mark_host_service
      mark_ordinary_guest
      mark_playwright_guest
      add_explanation "$path -> conservative Go impact: host + both guest images"
      ;;
    frontend/*)
      mark_frontend
      add_explanation "$path -> conservative frontend impact"
      ;;
    *)
      mark_host_os
      mark_ordinary_guest
      mark_playwright_guest
      add_explanation "$path -> unknown deployed path: conservative host + both guest images"
      ;;
  esac
done

if [[ -n "$output_file" ]]; then
  {
    echo "deploy_needed=${deploy_needed}"
    echo "deploy_host=${deploy_host}"
    echo "deploy_frontend=${deploy_frontend}"
    echo "deploy_host_service=${deploy_host_service}"
    echo "deploy_ordinary_guest=${deploy_ordinary_guest}"
    echo "deploy_playwright_guest=${deploy_playwright_guest}"
    echo "deploy_host_os=${deploy_host_os}"
    echo "deploy_vmctl_restart=${deploy_vmctl_restart}"
    echo "host_services=$(IFS=,; echo "${host_services[*]}")"
    echo "changed_paths<<EOF"
    printf '%s\n' "${changed[@]}"
    echo "EOF"
    echo "class_explanation<<EOF"
    printf '%s\n' "${explanations[@]}"
    echo "EOF"
  } >> "$output_file"
fi

cat <<EOF
deploy_needed=${deploy_needed}
deploy_host=${deploy_host}
deploy_frontend=${deploy_frontend}
deploy_host_service=${deploy_host_service}
deploy_ordinary_guest=${deploy_ordinary_guest}
deploy_playwright_guest=${deploy_playwright_guest}
deploy_host_os=${deploy_host_os}
deploy_vmctl_restart=${deploy_vmctl_restart}
host_services=$(IFS=,; echo "${host_services[*]}")
EOF

printf '%s\n' "${explanations[@]}"

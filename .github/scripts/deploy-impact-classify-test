#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
CLASSIFIER="$ROOT/.github/scripts/deploy-impact-classify"

run_classifier() {
  printf '%s\n' "$@" | "$CLASSIFIER"
}

assert_contains() {
  local haystack="$1"
  local needle="$2"
  if [[ "$haystack" != *"$needle"* ]]; then
    printf 'expected output to contain:\n%s\n\nactual output:\n%s\n' "$needle" "$haystack" >&2
    exit 1
  fi
}

assert_not_contains() {
  local haystack="$1"
  local needle="$2"
  if [[ "$haystack" == *"$needle"* ]]; then
    printf 'expected output not to contain:\n%s\n\nactual output:\n%s\n' "$needle" "$haystack" >&2
    exit 1
  fi
}

sourcecontract_testdata_output="$(
  run_classifier \
    "internal/sourcecontract/testdata/source_contract_matrix.json" \
    "internal/sourcecontract/matrix_test.go"
)"
assert_contains "$sourcecontract_testdata_output" "deploy_needed=false"
assert_contains "$sourcecontract_testdata_output" "internal/sourcecontract/testdata/source_contract_matrix.json -> ignored (docs/workflow/test artifact)"
assert_contains "$sourcecontract_testdata_output" "internal/sourcecontract/matrix_test.go -> ignored (docs/workflow/test artifact)"
assert_not_contains "$sourcecontract_testdata_output" "shared source contract dependency"

sourcecontract_runtime_output="$(run_classifier "internal/sourcecontract/evidence.go")"
assert_contains "$sourcecontract_runtime_output" "deploy_needed=true"
assert_contains "$sourcecontract_runtime_output" "deploy_host=true"
assert_contains "$sourcecontract_runtime_output" "deploy_host_service=true"
assert_contains "$sourcecontract_runtime_output" "deploy_vmctl_restart=true"
assert_contains "$sourcecontract_runtime_output" "deploy_active_vm_refresh=true"
assert_contains "$sourcecontract_runtime_output" "host_services=gateway,corpusd,proxy,sandbox,sourcecycled"
assert_contains "$sourcecontract_runtime_output" "internal/sourcecontract/evidence.go -> shared source contract dependency: runtime/platform service pointers + active VM refresh"

doccheck_tooling_output="$(
  run_classifier \
    ".gitignore" \
    "cmd/doccheck/main.go" \
    "scripts/doccheck" \
    "scripts/node-b-deploy-disk-preflight" \
    "docs/doc-authority-manifest.yaml" \
    "AGENTS.md"
)"
assert_contains "$doccheck_tooling_output" "deploy_needed=false"
assert_contains "$doccheck_tooling_output" ".gitignore -> ignored (repo metadata or docs checker tooling)"
assert_contains "$doccheck_tooling_output" "cmd/doccheck/main.go -> ignored (repo metadata or docs checker tooling)"
assert_contains "$doccheck_tooling_output" "scripts/doccheck -> ignored (repo metadata or docs checker tooling)"
assert_contains "$doccheck_tooling_output" "scripts/node-b-deploy-disk-preflight -> ignored (repo metadata or docs checker tooling)"
assert_contains "$doccheck_tooling_output" "docs/doc-authority-manifest.yaml -> ignored (docs/workflow/test artifact)"
assert_contains "$doccheck_tooling_output" "AGENTS.md -> ignored (top-level markdown)"
assert_not_contains "$doccheck_tooling_output" "conservative Go impact"
assert_not_contains "$doccheck_tooling_output" "unknown deployed path"

node_b_storage_tooling_output="$(
  run_classifier \
    "scripts/node-b-storage-report" \
    "scripts/node-b-storage-proof" \
    "scripts/node-b-storage-snapshot-gates" \
    "scripts/node-b-storage-verify-report" \
    "scripts/node-b-storage-vm-gates" \
    "scripts/node-b-data-img-snapshot" \
    "scripts/node-b-nix-root-report"
)"
assert_contains "$node_b_storage_tooling_output" "deploy_needed=false"
assert_contains "$node_b_storage_tooling_output" "scripts/node-b-storage-report -> ignored (Node B operator/report tooling; not deployed to host or guest closures)"
assert_contains "$node_b_storage_tooling_output" "scripts/node-b-storage-snapshot-gates -> ignored (Node B operator/report tooling; not deployed to host or guest closures)"
assert_contains "$node_b_storage_tooling_output" "scripts/node-b-storage-vm-gates -> ignored (Node B operator/report tooling; not deployed to host or guest closures)"
assert_contains "$node_b_storage_tooling_output" "scripts/node-b-data-img-snapshot -> ignored (Node B operator/report tooling; not deployed to host or guest closures)"
assert_contains "$node_b_storage_tooling_output" "scripts/node-b-nix-root-report -> ignored (Node B operator/report tooling; not deployed to host or guest closures)"
assert_not_contains "$node_b_storage_tooling_output" "unknown deployed path"
assert_not_contains "$node_b_storage_tooling_output" "ordinary_guest=true"
assert_not_contains "$node_b_storage_tooling_output" "playwright_guest=true"

node_a_tooling_output="$(
  run_classifier \
    "nix/node-a.nix" \
    "nix/node-a-hardware.nix" \
    "nix/node-a-disks.nix"
)"
assert_contains "$node_a_tooling_output" "deploy_needed=false"
assert_contains "$node_a_tooling_output" "nix/node-a.nix -> ignored (Node A mirror config; not deployed to Node B host or guest closures)"
assert_contains "$node_a_tooling_output" "nix/node-a-hardware.nix -> ignored (Node A mirror config; not deployed to Node B host or guest closures)"
assert_contains "$node_a_tooling_output" "nix/node-a-disks.nix -> ignored (Node A mirror config; not deployed to Node B host or guest closures)"
assert_not_contains "$node_a_tooling_output" "unknown deployed path"
assert_not_contains "$node_a_tooling_output" "ordinary_guest=true"
assert_not_contains "$node_a_tooling_output" "playwright_guest=true"

proxy_runtime_output="$(run_classifier "cmd/proxy/main.go")"
assert_contains "$proxy_runtime_output" "deploy_needed=true"
assert_contains "$proxy_runtime_output" "host_services=proxy"
assert_contains "$proxy_runtime_output" "cmd/proxy/main.go -> proxy host service"

sandbox_runtime_output="$(run_classifier "internal/runtime/run_acceptance.go")"
assert_contains "$sandbox_runtime_output" "deploy_needed=true"
assert_contains "$sandbox_runtime_output" "deploy_host=true"
assert_contains "$sandbox_runtime_output" "deploy_host_service=true"
assert_contains "$sandbox_runtime_output" "deploy_vmctl_restart=true"
assert_contains "$sandbox_runtime_output" "host_services=gateway,sandbox"
assert_contains "$sandbox_runtime_output" "internal/runtime/run_acceptance.go -> gateway/sandbox service pointers + vmctl runtime-package endpoint restart"

printf 'deploy-impact-classify-test: ok\n'

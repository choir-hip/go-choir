#!/usr/bin/env bash
set -euo pipefail

root=$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)
workflow="$root/.github/workflows/ci.yml"

require() {
  local pattern="$1"
  if ! grep -Fq -- "$pattern" "$workflow"; then
    echo "deploy workflow contract missing: $pattern" >&2
    exit 1
  fi
}

reject() {
  local pattern="$1"
  if grep -Fq -- "$pattern" "$workflow"; then
    echo "deploy workflow contract forbids: $pattern" >&2
    exit 1
  fi
}

require 'DEPLOY_COMMIT: ${{ github.sha }}'
require 'git fetch --no-tags origin "$DEPLOY_COMMIT"'
require 'git reset --hard "$DEPLOY_COMMIT"'
require 'x-choir-build-commit:'
require 'deploy-receipt.json'
require 'Refusing to publish an activation receipt with no verified artifacts'
require 'deploy-failures'
require 'verify_artifact_manifest'
require 'sandbox_runtime_commit=$(artifact_manifest_commit /var/lib/go-choir/services/sandbox/share/go-choir/build.json sandbox)'
require 'source scripts/node-b-sync-service-pointers'
require 'active_path="/var/lib/go-choir/services/${service}"'
require 'active_commit=$(artifact_manifest_commit "$active_path/share/go-choir/build.json" "$service")'
require 'active_digest=$(nix hash path --type sha256 "$active_path")'
require 'candidate_digest=$(nix hash path --type sha256 "$candidate_path" 2>/dev/null || true)'
require 'if [ "$candidate_commit" = "$active_commit" ] && [ "$candidate_digest" = "$active_digest" ]; then'
require 'fallback_path=$(resolve_service_package_from_unit "$service")'
require 'if [ "$fallback_commit" = "$active_commit" ] && [ "$fallback_digest" = "$active_digest" ]; then'
require 'package_commit="$active_commit"'
require 'for identity_service in "${identity_services[@]}"; do'
require 'if [ "$package_commit" != "$DEPLOY_COMMIT" ] || [ "$service_commit" != "$DEPLOY_COMMIT" ]; then'
require 'jq --arg service "$service" --arg path "$package_path" --arg digest "$package_digest" --arg commit "$package_commit"'
reject 'if [ "$candidate_commit" = "$DEPLOY_COMMIT" ]; then'
reject 'package_commit=$(verify_artifact_manifest "$package_path/share/go-choir/build.json" "$service")'
reject 'jq --arg service "$service" --arg path "$package_path" --arg digest "$package_digest" --arg commit "$service_commit"'
reject 'service_commit=$(curl -fsS --max-time 5 "http://127.0.0.1:${port}/health" | jq -er '\''.build.commit'\'')'
reject 'package_path=$(readlink -f "/var/lib/go-choir/services/${service}")'
require 'wait_for_sandbox_commit "$refresh_sandbox_url" "$refresh_vm_id" "$sandbox_runtime_commit"'
require 'select((.snapshot_kind // "") == "constructed-computer-version")'
require 'select((.snapshot_kind // "") != "constructed-computer-version")'
require 'Preserving immutable constructed computer ${immutable_vm_id}'
require 'No mutable active interactive computers need refresh'
reject 'git reset --hard origin/main'
reject 'fast_build_host_service'
reject 'active computer refresh failed; continuing'
reject 'if [ "$commit" = "$DEPLOY_COMMIT" ]; then'
reject 'DEPLOY_PLAYWRIGHT_GUEST'
reject 'deploy_playwright_guest'
reject 'guest-image-playwright'
reject 'guest-playwright'
reject 'playwright_guest'
reject 'DEPLOY_ORDINARY_GUEST'
reject 'deploy_ordinary_guest'
reject 'install_guest_image'
reject 'ordinary_guest'
reject '/tmp/guest-image-result'

identity_line=$(grep -nF 'selected service build identity mismatch' "$workflow" | cut -d: -f1)
receipt_line=$(grep -nF 'Published activation receipt' "$workflow" | cut -d: -f1)
if [ -z "$identity_line" ] || [ -z "$receipt_line" ] || [ "$receipt_line" -le "$identity_line" ]; then
  echo "activation receipt must be published after selected-service identity verification" >&2
  exit 1
fi

# Keep the EXIT-trap artifact default valid JSON. A malformed parameter
# expansion here silently suppresses the very failure evidence it should write.
receipt_artifacts='{}'
artifacts_json="${receipt_artifacts:-"{}"}"
jq -n --argjson artifacts "$artifacts_json" '{observed_artifacts: $artifacts}' |
  jq -e '.observed_artifacts == {}' >/dev/null

# Constructed ComputerVersion realizations are immutable function results. Global
# deploy refresh may update ordinary active primaries, never these frozen rows.
mixed_inventory='{"ownerships":[{"user_id":"mutable-owner","desktop_id":"primary","vm_id":"vm-mutable","sandbox_url":"http://10.0.0.2:8085","state":"active","kind":"interactive"},{"user_id":"frozen-owner","desktop_id":"primary","vm_id":"vm-frozen","sandbox_url":"http://10.0.0.3:8085","state":"active","kind":"interactive","snapshot_kind":"constructed-computer-version","construction_version":{"code_ref":"code:sha256:frozen","artifact_program_ref":"artifact-program:sha256:frozen"},"construction_disk_receipt_id":"disk-instantiation:sha256:frozen"},{"user_id":"sleeping-owner","desktop_id":"primary","vm_id":"vm-sleeping","state":"hibernated","kind":"interactive"}]}'
mutable_ids=$(printf '%s' "$mixed_inventory" | jq -r '.ownerships[] | select(.state == "active") | select((.kind == null) or (.kind == "") or (.kind == "interactive")) | select((.snapshot_kind // "") != "constructed-computer-version") | .vm_id')
immutable_ids=$(printf '%s' "$mixed_inventory" | jq -r '.ownerships[] | select(.state == "active") | select((.kind == null) or (.kind == "") or (.kind == "interactive")) | select((.snapshot_kind // "") == "constructed-computer-version") | .vm_id')
[ "$mutable_ids" = "vm-mutable" ]
[ "$immutable_ids" = "vm-frozen" ]

echo "deploy workflow contract tests passed"
